# AI Study Bootcamp — 환경변수 템플릿
# 이 파일을 .env로 복사하고 값 채우기. .env는 절대 커밋하지 말 것.
#
# cp .env.example .env

# ─────────────────────────────────────────────────────
# LLM Provider API keys
# ─────────────────────────────────────────────────────
# https://platform.openai.com/api-keys
OPENAI_API_KEY=sk-...

# https://console.anthropic.com/settings/keys
ANTHROPIC_API_KEY=sk-ant-...

# https://aistudio.google.com/apikey
GOOGLE_API_KEY=...

# ─────────────────────────────────────────────────────
# Default models (Day별로 바꿔가며 실험)
# ─────────────────────────────────────────────────────
OPENAI_MODEL=gpt-4o-mini
ANTHROPIC_MODEL=claude-haiku-4-5
GEMINI_MODEL=gemini-2.5-flash

# Embedding
OPENAI_EMBEDDING_MODEL=text-embedding-3-small
GEMINI_EMBEDDING_MODEL=text-embedding-004
LOCAL_EMBEDDING_MODEL=sentence-transformers/all-MiniLM-L6-v2

# ─────────────────────────────────────────────────────
# Local infra
# ─────────────────────────────────────────────────────
# Qdrant (Day 6-14)
QDRANT_URL=http://localhost:6333
QDRANT_API_KEY=

# Ollama (Day 13)
OLLAMA_BASE_URL=http://localhost:11434/v1
OLLAMA_MODEL=qwen2.5:7b

# Langfuse self-hosted (Day 12)
# docker-compose up 후 웹에서 키 생성
LANGFUSE_HOST=http://localhost:3000
LANGFUSE_PUBLIC_KEY=
LANGFUSE_SECRET_KEY=

# ─────────────────────────────────────────────────────
# Optional / Day 13
# ─────────────────────────────────────────────────────
# https://www.runpod.io/console/user/settings
RUNPOD_API_KEY=
RUNPOD_ENDPOINT_ID=

# Tavily 무료 tier (Day 5 web_search tool 용)
TAVILY_API_KEY=

# Cohere Rerank 무료 trial (Day 8 reranker 대체 옵션)
COHERE_API_KEY=

# ─────────────────────────────────────────────────────
# Behavior
# ─────────────────────────────────────────────────────
LOG_LEVEL=INFO
DEFAULT_TEMPERATURE=0.2
REQUEST_TIMEOUT=60
