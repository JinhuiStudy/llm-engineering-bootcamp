# AI Study Bootcamp — 환경변수 템플릿 (2026-04 기준)
# 이 파일을 .env로 복사하고 값 채우기. .env는 절대 커밋 금지.
#
#   cp .env.example .env && $EDITOR .env

# ─────────────────────────────────────────────────────
# LLM Provider API keys (필수 3사)
# ─────────────────────────────────────────────────────
# https://platform.openai.com/api-keys
OPENAI_API_KEY=sk-proj-...

# https://console.anthropic.com/settings/keys
ANTHROPIC_API_KEY=sk-ant-...

# https://aistudio.google.com/apikey  (무료 tier 있음)
GOOGLE_API_KEY=AIza...

# ─────────────────────────────────────────────────────
# Default models (Day별로 실험하며 변경)
# ─────────────────────────────────────────────────────
# 기본: 빠른/저렴한 workhorse
OPENAI_MODEL=gpt-4o-mini
ANTHROPIC_MODEL=claude-haiku-4-5
GEMINI_MODEL=gemini-2.5-flash

# 품질 필요 시 (Day 8+)
# OPENAI_MODEL=gpt-4o
# ANTHROPIC_MODEL=claude-sonnet-4-6
# GEMINI_MODEL=gemini-2.5-pro

# Reasoning 필요 (Day 9 judge / Day 10 planner)
# OPENAI_MODEL=o1-mini
# ANTHROPIC_MODEL=claude-opus-4-7

# ─────────────────────────────────────────────────────
# Embedding
# ─────────────────────────────────────────────────────
OPENAI_EMBEDDING_MODEL=text-embedding-3-small
# 품질 우선: text-embedding-3-large (dimensions=1024로 자르기 권장)
GEMINI_EMBEDDING_MODEL=text-embedding-004
LOCAL_EMBEDDING_MODEL=intfloat/multilingual-e5-large
# 빠른/작은 대안: sentence-transformers/all-MiniLM-L6-v2

# Voyage (Anthropic 권장) — Day 6 Stretch
# https://www.voyageai.com/
VOYAGE_API_KEY=

# ─────────────────────────────────────────────────────
# Local infra (Docker)
# ─────────────────────────────────────────────────────
# Qdrant (Day 6-14)
QDRANT_URL=http://localhost:6333
QDRANT_API_KEY=

# Ollama (Day 13) — 한국어 강함 Qwen3 권장
OLLAMA_BASE_URL=http://localhost:11434/v1
OLLAMA_MODEL=qwen3:8b
# 대안: llama3.3:8b-instruct-q4_K_M / gpt-oss:20b

# Langfuse self-hosted (Day 12)
# make langfuse-up 후 http://localhost:3000 에서 가입 → Settings → API Keys
LANGFUSE_HOST=http://localhost:3000
LANGFUSE_PUBLIC_KEY=pk-lf-...
LANGFUSE_SECRET_KEY=sk-lf-...

# Phoenix (Day 12 선택) — local에서 띄우면 localhost:6006
PHOENIX_COLLECTOR_ENDPOINT=http://localhost:6006

# ─────────────────────────────────────────────────────
# Cloud (Day 13 / 선택)
# ─────────────────────────────────────────────────────
# https://www.runpod.io/console/user/settings
RUNPOD_API_KEY=
RUNPOD_ENDPOINT_ID=

# Tavily (Day 5 web search, 무료 1000 req/mo)
# https://tavily.com/
TAVILY_API_KEY=

# Cohere (Day 8 reranker 대안, 무료 trial)
# https://dashboard.cohere.com/
COHERE_API_KEY=

# ─────────────────────────────────────────────────────
# Behavior / 공통
# ─────────────────────────────────────────────────────
LOG_LEVEL=INFO
# 권장: 일반 generation 0.2, RAG/분류 0.0, 창의 0.7
DEFAULT_TEMPERATURE=0.2
REQUEST_TIMEOUT=60

# Prompt/resource 디렉토리 override (optional)
# PROMPT_DIR=/path/to/prompts

# Day 5 tool sandbox 기준 디렉토리
SANDBOX_ROOT=/Users/parkjinhui/Desktop/dev/ai-study

# Day 9/12 eval 결과 저장
EVAL_OUTPUT_DIR=./results/eval

# ─────────────────────────────────────────────────────
# Day 14 포트폴리오 (LLM_PROVIDER env로 런타임 스위치)
# ─────────────────────────────────────────────────────
# LLM_PROVIDER=openai|anthropic|ollama|runpod
LLM_PROVIDER=anthropic
EMBED_PROVIDER=openai
# EMBED_PROVIDER=voyage|local-e5

# ─────────────────────────────────────────────────────
# Safety rails
# ─────────────────────────────────────────────────────
# Agent 무한루프 방지
AGENT_MAX_ITERATIONS=10
AGENT_TOKEN_BUDGET=50000
AGENT_TIMEOUT_SEC=120

# Daily cost hard limit (없어도 됨 — 개발자 주의 알림용)
DAILY_COST_LIMIT_USD=20
